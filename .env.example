# Coboard local dev environment
# Copy to .env and adjust as needed

# Board service
BoardService__ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=coboard_board;Username=coboard;Password=coboard_dev

# Auth service
AuthService__ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=coboard_auth;Username=coboard;Password=coboard_dev
AuthService__Jwt__SigningKey=dev-only-replace-with-32-byte-secret-key
AuthService__Jwt__Issuer=coboard-auth
AuthService__Jwt__Audience=coboard

# Presence service
PresenceService__ConnectionStrings__Redis=localhost:6379
